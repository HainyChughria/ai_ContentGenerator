NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ai-saas
CLIENT_URL=http://localhost:3000
API_URL=http://localhost:5000
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_EXPIRES_IN=15m
GROQ_API_KEY=gsk_xxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile
# Create a fine-grained token with "Make calls to Inference Providers" enabled.
HF_TOKEN=hf_xxxxxxxxx
HF_IMAGE_MODEL=stabilityai/stable-diffusion-xl-base-1.0
HF_IMAGE_FALLBACK_MODEL=stable-diffusion-v1-5/stable-diffusion-v1-5
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL="AI SaaS <onboarding@resend.dev>"
